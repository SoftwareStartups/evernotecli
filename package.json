{
  "name": "@softwarestartups/evercli",
  "version": "2.2.0",
  "description": "Bun-native TypeScript Evernote CLI and MCP server",
  "license": "MIT",
  "author": "SoftwareStartups",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoftwareStartups/evernotecli.git"
  },
  "homepage": "https://github.com/SoftwareStartups/evernotecli#readme",
  "bugs": {
    "url": "https://github.com/SoftwareStartups/evernotecli/issues"
  },
  "keywords": [
    "evernote",
    "cli",
    "mcp",
    "model-context-protocol",
    "bun",
    "typescript"
  ],
  "type": "module",
  "bin": {
    "evercli": "build/index.js"
  },
  "main": "build/index.js",
  "scripts": {
    "build": "tsc && cp -r src/edam build/edam",
    "start": "bun run build/index.js",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/",
    "test:e2e": "bun test tests/e2e/",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:e2e",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "lint": "bunx biome lint .",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "bunqueue": "^2.6.19",
    "clerc": "^1.3.1",
    "fast-xml-parser": "^5.3.2",
    "got": "^14.6.6",
    "oauth": "^0.10.2",
    "pino": "^10.3.1",
    "thrift": "^0.22.0",
    "ts-rate-limiter": "^0.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/oauth": "^0.9.6",
    "@types/thrift": "^0.10.17",
    "bun-types": "^1.3.10",
    "lefthook": "2.1.5",
    "express": "^5.2.1",
    "typescript": "^5.9.3"
  }
}
